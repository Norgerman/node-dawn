{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 31,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_VISIBILITY_PRESET": "hidden",
                "CMAKE_VISIBILITY_INLINES_HIDDEN": "ON",
                "DAWN_BUILD_NODE_BINDINGS": "ON",
                "DAWN_USE_X11": "OFF",
                "NODE_BINDING_BINARY_DIR": "${sourceDir}/bin"
            }
        },
        {
            "name": "win32-x64",
            "inherits": "default",
            "cacheVariables": {
                "DAWN_USE_BUILT_DXC": "ON"
            },
            "generator": "Visual Studio 18 2026",
            "architecture": "x64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux-x64",
            "inherits": "default",
            "cacheVariables": {},
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-arm64",
            "inherits": "default",
            "cacheVariables": {},
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "darwin-arm64",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_OSX_SYSROOT": "/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk"
            },
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configuration": "Release",
            "configurePreset": "default",
            "targets": [
                "dawn_node"
            ]
        },
        {
            "name": "win32-x64",
            "inherits": "default",
            "configurePreset": "win32-x64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux-x64",
            "inherits": "default",
            "configurePreset": "linux-x64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-arm64",
            "inherits": "default",
            "configurePreset": "linux-arm64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "darwin-arm64",
            "inherits": "default",
            "configurePreset": "darwin-arm64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        }
    ]
}
